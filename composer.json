{
    "name": "dnsl48/hydrogen",
    "description": "Declarative data definition framework for PHP (Schemas, DTOs, Atomic types, Native Objects)",
    "type": "library",
    "homepage": "https://github.com/dnsl48/php--hydrogen",
    "license": "MIT/Apache-2.0",
    "autoload": {
        "psr-4": {
            "Hydrogen\\": "src/Hydrogen/"
        }
    },
    "authors": [
        {
            "name": "Serge Latyntsev",
            "email": "dnsl48@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "test": "XDEBUG_MODE=coverage phpunit",
        "phpstan": "phpstan"
    },
    "require": {
        "php": "^8.3",
        "symfony/serializer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-strict-rules": "^1.5",
        "phpstan/phpstan-phpunit": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
